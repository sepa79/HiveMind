{
  "profile_id": "base",
  "version": "v1",
  "profile_ref": "base@v1",
  "label": "Base AI Project Starter",
  "description": "Reference-first AI contributor starter files for a generic repository.",
  "template_variables": [
    "PROJECT_NAME",
    "PROJECT_ID",
    "PROFILE_REF",
    "HIVEMIND_API_URL"
  ],
  "files": [
    { "source": "AGENTS.md", "target": "AGENTS.md", "required": true },
    { "source": "BOOTSTRAP_PROMPT.md", "target": "BOOTSTRAP_PROMPT.md", "required": false },
    { "source": "BOOTSTRAP_PROMPT_SIMPLE.md", "target": "BOOTSTRAP_PROMPT_SIMPLE.md", "required": false },
    { "source": "docs/ARCHITECTURE.md", "target": "docs/ARCHITECTURE.md", "required": true },
    { "source": "docs/adr/README.md", "target": "docs/adr/README.md", "required": false },
    { "source": "docs/ai/AI_HATS.md", "target": "docs/ai/AI_HATS.md", "required": true },
    { "source": "docs/ai/COMMANDS.md", "target": "docs/ai/COMMANDS.md", "required": true },
    { "source": "docs/ai/EVIDENCE_TEMPLATE.md", "target": "docs/ai/EVIDENCE_TEMPLATE.md", "required": false },
    { "source": "docs/ai/HIVEMIND_RULES.md", "target": "docs/ai/HIVEMIND_RULES.md", "required": true },
    { "source": "docs/ai/JESTER_CHECKS.md", "target": "docs/ai/JESTER_CHECKS.md", "required": true },
    { "source": "docs/ai/LESSONS_LEARNED.md", "target": "docs/ai/LESSONS_LEARNED.md", "required": false },
    { "source": "docs/ai/PROJECT_CONTEXT.md", "target": "docs/ai/PROJECT_CONTEXT.md", "required": true },
    { "source": "docs/ai/PR_PREPARATION.md", "target": "docs/ai/PR_PREPARATION.md", "required": false },
    { "source": "docs/ai/REVIEW_CHECKS.md", "target": "docs/ai/REVIEW_CHECKS.md", "required": true },
    { "source": "docs/ai/TASK_TEMPLATE.md", "target": "docs/ai/TASK_TEMPLATE.md", "required": false },
    { "source": "docs/specs/README.md", "target": "docs/specs/README.md", "required": true }
  ],
  "rules": [
    {
      "rule_id": "use_hivemind",
      "label": "Use HiveMind for meaningful work",
      "description": "Start a HiveMind session for meaningful work, record concise decisions/progress/risks, and end the session when complete.",
      "severity": "required",
      "check_mode": "manual_confirm",
      "evidence_hint": "HiveMind session id or closeout summary.",
      "tags": ["hivemind", "memory"]
    },
    {
      "rule_id": "no_silent_fallbacks",
      "label": "No silent fallbacks",
      "description": "Do not add hidden fallback chains, heuristic recovery, or implicit compatibility behavior.",
      "severity": "required",
      "check_mode": "manual_confirm",
      "evidence_hint": "Review summary confirming failure behavior is explicit.",
      "tags": ["architecture", "nff"]
    },
    {
      "rule_id": "ssot_contracts",
      "label": "Keep contracts single-source",
      "description": "Use one canonical schema/spec per public API, config shape, or integration boundary.",
      "severity": "required",
      "check_mode": "file_reference_required",
      "evidence_hint": "Reference the canonical schema/spec touched by the change.",
      "tags": ["contracts", "schema"]
    },
    {
      "rule_id": "test_meaningful_behavior",
      "label": "Test meaningful behavior",
      "description": "Test behavior, contracts, and failure handling instead of decorative mocks.",
      "severity": "required",
      "check_mode": "command_reference_required",
      "evidence_hint": "Command and result summary for the relevant test slice.",
      "tags": ["testing"]
    }
  ]
}
