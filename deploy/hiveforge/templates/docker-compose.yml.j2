{% set opensearch_admin_secret_path = '/run/secrets/' ~ hivemind_opensearch_admin_password_secret %}
{% set hivemind_opensearch_password_secret_path = '/run/secrets/' ~ hivemind_opensearch_password_secret %}
services:
  opensearch:
    image: opensearchproject/opensearch:2.17.1
    restart: on-failure
    environment:
      discovery.type: single-node
      OPENSEARCH_JAVA_OPTS: "-Xms512m -Xmx512m"
{% if not hivemind_swarm_profile %}
      OPENSEARCH_INITIAL_ADMIN_PASSWORD: "{{ opensearch_initial_admin_password }}"
{% endif %}
{% if hivemind_swarm_profile %}
    entrypoint: ["/bin/bash", "-c"]
    command:
      - "export OPENSEARCH_INITIAL_ADMIN_PASSWORD=\"$$(cat {{ opensearch_admin_secret_path }})\"; exec ./opensearch-docker-entrypoint.sh opensearch"
    secrets:
      - "{{ hivemind_opensearch_admin_password_secret }}"
{% endif %}
    volumes:
      - opensearch-data:/usr/share/opensearch/data
    healthcheck:
{% if hivemind_swarm_profile %}
      test: ["CMD-SHELL", "status=$$(curl -k -sS -o /dev/null -w '%{http_code}' https://127.0.0.1:9200); test \"$$status\" = \"200\" -o \"$$status\" = \"401\""]
{% else %}
      test: ["CMD-SHELL", "curl -k -fsS -u admin:$$OPENSEARCH_INITIAL_ADMIN_PASSWORD https://127.0.0.1:9200/_cluster/health >/dev/null"]
{% endif %}
      interval: 10s
      timeout: 5s
      retries: 30
      start_period: 30s
{% if hivemind_swarm_profile %}
    deploy:
      restart_policy:
        condition: on-failure
        delay: 5s
{% else %}
    deploy:
      restart_policy:
        condition: on-failure
        delay: 5s
{% endif %}

  opensearch-init:
    image: "{{ hivemind_api_image }}"
    restart: on-failure
    labels:
      hiveforge.runtime.ignore: "true"
    environment:
      NODE_TLS_REJECT_UNAUTHORIZED: "{{ '1' if hivemind_opensearch_tls_reject_unauthorized == 'true' else '0' }}"
{% if hivemind_swarm_profile %}
      OPENSEARCH_INITIAL_ADMIN_PASSWORD_FILE: "{{ opensearch_admin_secret_path }}"
      HIVEMIND_OPENSEARCH_PASSWORD_FILE: "{{ hivemind_opensearch_password_secret_path }}"
{% else %}
      OPENSEARCH_INITIAL_ADMIN_PASSWORD: "{{ opensearch_initial_admin_password }}"
      HIVEMIND_OPENSEARCH_PASSWORD: "{{ hivemind_opensearch_password }}"
{% endif %}
      HIVEMIND_OPENSEARCH_USERNAME: "{{ hivemind_opensearch_username }}"
      HIVEMIND_OPENSEARCH_NODE: "{{ hivemind_opensearch_node }}"
      HIVEMIND_OPENSEARCH_INDEX_PREFIX: "{{ hivemind_opensearch_index_prefix }}"
    command: ["node", "scripts/opensearch-init.mjs"]
{% if hivemind_swarm_profile %}
    secrets:
      - "{{ hivemind_opensearch_admin_password_secret }}"
      - "{{ hivemind_opensearch_password_secret }}"
{% endif %}
{% if hivemind_swarm_profile %}
    deploy:
      labels:
        hiveforge.runtime.ignore: "true"
      restart_policy:
        condition: on-failure
        delay: 5s
{% else %}
    deploy:
      restart_policy:
        condition: on-failure
        delay: 5s
{% endif %}

  hivemind-api:
    image: "{{ hivemind_api_image }}"
    restart: on-failure
    environment:
      HIVEMIND_API_PORT: "4010"
      HIVEMIND_STORAGE_BACKEND: opensearch
      HIVEMIND_OPENSEARCH_NODE: "{{ hivemind_opensearch_node }}"
      HIVEMIND_OPENSEARCH_INDEX_PREFIX: "{{ hivemind_opensearch_index_prefix }}"
      HIVEMIND_OPENSEARCH_USERNAME: "{{ hivemind_opensearch_username }}"
{% if hivemind_swarm_profile %}
      HIVEMIND_OPENSEARCH_PASSWORD_FILE: "{{ hivemind_opensearch_password_secret_path }}"
{% else %}
      HIVEMIND_OPENSEARCH_PASSWORD: "{{ hivemind_opensearch_password }}"
{% endif %}
      HIVEMIND_OPENSEARCH_TLS_REJECT_UNAUTHORIZED: "{{ hivemind_opensearch_tls_reject_unauthorized }}"
      HIVEMIND_RULESET_CATALOG_PATH: "{{ hivemind_ruleset_catalog_path }}"
      HIVEMIND_RULESET_CATALOG_SOURCE_URL: "{{ hivemind_ruleset_catalog_source_url }}"
{% if hivemind_swarm_profile %}
    secrets:
      - "{{ hivemind_opensearch_password_secret }}"
{% endif %}
    ports:
{% if hivemind_swarm_profile %}
      - target: 4010
        published: {{ hivemind_api_port }}
        protocol: tcp
{% else %}
      - "{{ hivemind_api_port }}:4010"
{% endif %}
{% if hivemind_swarm_profile %}
    deploy:
      restart_policy:
        condition: on-failure
        delay: 5s
{% else %}
    deploy:
      restart_policy:
        condition: on-failure
        delay: 5s
{% endif %}

  hivemind-mcp:
    image: "{{ hivemind_api_image }}"
    restart: on-failure
    command: ["node", "hivemind-mcp/src/server.mjs"]
    environment:
      HIVEMIND_MCP_TRANSPORT: http
      HIVEMIND_MCP_HOST: 0.0.0.0
      HIVEMIND_MCP_PORT: "4011"
      HIVEMIND_API_BASE_URL: "{{ hivemind_internal_api_base_url }}"
    ports:
{% if hivemind_swarm_profile %}
      - target: 4011
        published: {{ hivemind_mcp_port }}
        protocol: tcp
{% else %}
      - "{{ hivemind_mcp_port }}:4011"
{% endif %}
    depends_on:
      - hivemind-api
{% if hivemind_swarm_profile %}
    deploy:
      restart_policy:
        condition: on-failure
        delay: 5s
{% else %}
    deploy:
      restart_policy:
        condition: on-failure
        delay: 5s
{% endif %}

volumes:
  opensearch-data:

{% if hivemind_swarm_profile %}
secrets:
  "{{ hivemind_opensearch_admin_password_secret }}":
    external: true
  "{{ hivemind_opensearch_password_secret }}":
    external: true
{% endif %}
